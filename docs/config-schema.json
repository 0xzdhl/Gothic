{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Gothic Configuration",
    "description": "Gothic Configuration Definition",
    "type": "object",
    "properties": {
        "trae_executable_path": {
            "type": "string",
            "description": "The absolute path to Trae executable file."
        },
        "command_strategy": {
            "type": "string",
            "description": "How the Gothic handles human in the loop command (operation), for example: shell execution.",
            "enum": [
                "allow",
                "deny",
                "llm"
            ],
            "default": "allow"
        },
        "question_strategy": {
            "type": "string",
            "description": "How the Gothic handles human in the loop question (operation). \n\n- skip: skip all the questions. \n- auto: select an option randomly.\n- llm: invoke llm to decide.",
            "enum": [
                "skip",
                "auto",
                "llm"
            ],
            "default": "auto"
        },
        "max_concurrent_task": {
            "type": "integer",
            "description": "The maximum number of concurrent tasks. Recommended <= 10.",
            "minimum": 1,
            "default": 5
        },
        "max_task_action_retry": {
            "type": "integer",
            "description": "The maximum attempt for task actions, command execution, questions, .etc.",
            "minimum": 1,
            "default": 3
        },
        "model": {
            "type": "object",
            "description": "LLM Configuration.",
            "properties": {
                "api_key": {
                    "type": "string",
                    "description": "OpenAI compatible key."
                },
                "base_url": {
                    "type": "string",
                    "description": "OpenAI compatible base url."
                },
                "model_name": {
                    "type": "string",
                    "description": "Model name used when command_strategy or question_strategy is llm.",
                    "default": "gpt-5-mini"
                }
            },
            "required": [
                "api_key",
                "base_url"
            ]
        }
    },
    "required": [
        "trae_executable_path"
    ]
}